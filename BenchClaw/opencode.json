  "command": {
    "benchclaw-pipeline": {
      "description": "Run the complete BenchClaw Stage 1-5 hierarchy with autonomous subagent and sub-subagent dispatch",
      "agent": "benchclaw-pipeline",
      "subtask": false,
      "template": "Run the BenchClaw benchmark pipeline for the request below. Follow benchmark-pipeline/SKILL.md exactly. Use this hierarchy: pipeline primary -> stage managers -> atomic/source/specialist sub-subagents. Dispatch independent source branches, artifact checks, reviews, and validation tasks in parallel when their inputs are ready. Never bypass stage gates. Stop at each required user checkpoint unless the instruction explicitly permits continuing. Task:\n\n$ARGUMENTS"
    },
    "benchclaw-stage1": {
      "description": "Run Stage 1 draft generation manager",
      "agent": "stage1-draft-manager",
      "subtask": true,
      "template": "Run Stage 1 according to benchmark-stage1-draft/SKILL.md. Follow the actual node-based DAG and ready-set rules in that skill, not an external phase tree. Preserve the Stage 1 flow 00/05/06 -> 01 -> 02/03 -> 04 -> 07 -> 08 -> 09/10/11 -> 12 -> 13. Treat nodes 05 and 06 as external capability-document ingestion, and keep nodes 09, 10, and 11 parallel once node 08 is complete. Stage 1 is complete only when benchmark_draft.md, design_traceability_table.csv, execution_plan.md, stage2_handoff.yaml, and _stage1_report.md exist under WORKSPACE_ROOT/stage1 according to benchmark-stage1-draft/SKILL.md. Run the Stage 1 gate and return artifacts, verdict, risks, and next checkpoint.\n\n$ARGUMENTS"
    },
    "benchclaw-stage2": {
      "description": "Run Stage 2 data collection manager",
      "agent": "stage2-data-collect-manager",
      "subtask": true,
      "template": "Run Stage 2 according to benchmark-stage2-data-collect/SKILL.md. Follow the actual node-based DAG and ready-set rules in that skill: initial ready nodes are 13 and 14, then 15 and 16 become ready after 13, and 17 becomes ready only after both 13 and 14 complete. This is one shared Stage 2 skill with three terminal collection branches, not a phase-based merge pipeline. Read Stage1 execution-plan outputs, register simulator adapters in node 14, then materialize real-image, existing-benchmark, and simulator collection artifacts under WORKSPACE_ROOT/stage2/15-real-image-acquisition, 16-existing-benchmark-acquisition, and 17-simulator-multimodal-gt-acquisition. Do not invent shared summary artifacts that are not declared by benchmark-stage2-data-collect/SKILL.md. Run the Stage 2 gate using the actual terminal DONE.json files from nodes 15, 16, and 17.\n\n$ARGUMENTS"
    },
    "benchclaw-stage3": {
      "description": "Run Stage 3 evidence-compiler manager",
      "agent": "stage3-data-clean-manager",
      "subtask": true,
      "template": "Run Stage 3 according to benchmark-stage3-evidence-compiler/SKILL.md. Follow the actual node-based DAG and ready-set rules in that skill: initial ready nodes are 15, 16, 17, and 27; then 21/22/23; then 24/25/26; then terminal nodes 18/19/20. This is an evidence-compiler DAG, not a shared phase pipeline with source_work/final contracts. Read Stage2 terminal outputs, run unified-format normalization and Data-Juicer cleaning through nodes 21-26, register semi-supervised tools at node 27, then produce terminal outputs at nodes 18, 19, and 20. Do not invent stage3/final or STAGE4_INPUT_MANIFEST artifacts that are not declared by benchmark-stage3-evidence-compiler/SKILL.md. Run the Stage 3 gate using the actual terminal DONE.json files from nodes 18, 19, and 20.\n\n$ARGUMENTS"
    },
    "benchclaw-source-simulator": {
      "description": "Internal parallel worker for simulator source_type branch work",
      "agent": "source-simulator-worker",
      "subtask": true,
      "template": "Run only the simulator branch work that the current BenchClaw parent stage actually delegates. Do not run the whole stage and do not invent a simulator-only stage contract. Follow the parent manager's active SKILL.md exactly. In Stage 1, this worker is only advisory support for simulator capability/source analysis if the parent manager explicitly asks for bounded simulator-specific exploration; all final Stage 1 artifacts must still match benchmark-stage1-draft/SKILL.md. In Stage 2, operate only within the simulator branch defined by benchmark-stage2-data-collect/SKILL.md, primarily nodes 14 and 17, preserving simulator GT/API provenance and materializing observations, manifests, provenance, and collection evidence under the declared WORKSPACE_ROOT/stage2 node outputs. In Stage 3, operate only within the simulator-derived path defined by benchmark-stage3-evidence-compiler/SKILL.md, primarily nodes 17, 23, 26, and 20, preserving privileged GT and returning merge-ready paths and evidence. Return branch status, artifact paths, blockers, and merge notes.\n\n$ARGUMENTS"
    },
    "benchclaw-source-dataset": {
      "description": "Internal parallel worker for existing_dataset source_type branch work",
      "agent": "source-dataset-worker",
      "subtask": true,
      "template": "Run only the existing_dataset branch work that the current BenchClaw parent stage actually delegates. Do not run the whole stage and do not invent a dataset-only stage contract. Follow the parent manager's active SKILL.md exactly. In Stage 1, this worker is only advisory support for existing-benchmark capability/source analysis if the parent manager explicitly asks for bounded dataset-specific exploration; all final Stage 1 artifacts must still match benchmark-stage1-draft/SKILL.md. In Stage 2, operate only within the existing-benchmark branch defined by benchmark-stage2-data-collect/SKILL.md, primarily node 16, preserving source IDs, official annotation provenance, ingest errors, raw samples, manifests, and dataset-scoped evidence under the declared WORKSPACE_ROOT/stage2 node outputs. In Stage 3, operate only within the benchmark-derived path defined by benchmark-stage3-evidence-compiler/SKILL.md, primarily nodes 16, 22, 25, and 19, preserving original annotation provenance and writing pseudo annotations only as tool_generated candidates with needs_human_review. Return branch status, artifact paths, blockers, and merge notes.\n\n$ARGUMENTS"
    },
    "benchclaw-source-realdata": {
      "description": "Internal parallel worker for real_data source_type branch work",
      "agent": "source-realdata-worker",
      "subtask": true,
      "template": "Run only the real_data branch work that the current BenchClaw parent stage actually delegates. Do not run the whole stage and do not invent a real-data-only stage contract. Follow the parent manager's active SKILL.md exactly. In Stage 1, this worker is only advisory support for real-data capability/source analysis if the parent manager explicitly asks for bounded real-data-specific exploration; all final Stage 1 artifacts must still match benchmark-stage1-draft/SKILL.md. In Stage 2, operate only within the real-image branch defined by benchmark-stage2-data-collect/SKILL.md, primarily node 15, preserving metadata extraction, registration, annotation gaps, images, manifests, and real-data-scoped evidence under the declared WORKSPACE_ROOT/stage2 node outputs. In Stage 3, operate only within the real-image path defined by benchmark-stage3-evidence-compiler/SKILL.md, primarily nodes 15, 21, 24, and 18, never convert inferred labels into GT, and write pseudo annotations only as tool_generated candidates with needs_human_review. Return branch status, artifact paths, blockers, and merge notes.\n\n$ARGUMENTS"
    },
    "benchclaw-stage4": {
      "description": "Run Stage 4 evalset and metric build manager",
      "agent": "stage4-build-manager",
      "subtask": true,
      "template": "Run Stage 4 according to benchmark-stage4-build/SKILL.md. Enforce observation grounding and no answer leakage. Metric library must be executable with metrics, aggregators, tests, and evaluator smoke run before PASS.\n\n$ARGUMENTS"
    },
    "benchclaw-stage5": {
      "description": "Run Stage 5 canary-first evaluation manager",
      "agent": "stage5-eval-manager",
      "subtask": true,
      "template": "Run Stage 5 according to benchmark-stage5-eval/SKILL.md. Build eval prompt/config, run canary first, block full eval on canary FAIL, localize rollback when needed, and only run full API/metrics after PASS or explicit waiver.\n\n$ARGUMENTS"
    },
    "benchclaw-review": {
      "description": "Review a BenchClaw stage, skill, or cross-stage contract",
      "agent": "stage-reviewer",
      "subtask": true,
      "template": "Review this BenchClaw scope. Focus on stage hierarchy, subagent delegation safety, artifact contracts, gate bypass risk, workspace isolation, data provenance, metric executability, and regression gaps.\n\n$ARGUMENTS"
    },
    "benchclaw-root-cause": {
      "description": "Diagnose a failed BenchClaw gate or pipeline regression",
      "agent": "root-cause-analyst",
      "subtask": true,
      "template": "Diagnose this failed BenchClaw pipeline gate. Localize to stage -> phase -> skill -> artifact -> rule gap -> minimal fix. Include invalidated downstream artifacts and rollback recommendation.\n\n$ARGUMENTS"
    },
    "benchclaw-contract": {
      "description": "Explore and verify SKILL.md contracts",
      "agent": "skill-contract-explorer",
      "subtask": true,
      "template": "Explore this BenchClaw skill contract. Return frontmatter, phase chain, required inputs, outputs, gates, delegation rules, parallelizable branches, and downstream handoff contract.\n\n$ARGUMENTS"
    }
  }
}
