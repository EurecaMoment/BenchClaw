{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "record_id",
    "simulator_gt",
    "provenance"
  ],
  "properties": {
    "record_id": {
      "type": "string"
    },
    "simulator_gt": {
      "type": "object"
    },
    "source_type": {
      "const": "simulator_privileged_gt"
    },
    "provenance": {
      "type": "object"
    },
    "consistency_checks": {
      "type": "object"
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}