{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "record_id",
    "simulator_gt",
    "provenance",
    "artifact_paths"
  ],
  "properties": {
    "record_id": {
      "type": "string"
    },
    "simulator_gt": {
      "type": "object"
    },
    "artifact_paths": {
      "type": "object",
      "required": [
        "original",
        "semantic_entity_segmentation",
        "depth",
        "gt"
      ],
      "properties": {
        "original": {
          "type": "string",
          "pattern": "^WORKSPACE_ROOT/stage3/simulator/.+/original/.+"
        },
        "semantic_entity_segmentation": {
          "type": "string",
          "pattern": "^WORKSPACE_ROOT/stage3/simulator/.+/semantic_entity_segmentation/.+"
        },
        "depth": {
          "type": "string",
          "pattern": "^WORKSPACE_ROOT/stage3/simulator/.+/depth/.+"
        },
        "gt": {
          "type": "string",
          "pattern": "^WORKSPACE_ROOT/stage3/simulator/.+/gt/.+"
        }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "source_type": {
      "const": "simulator_privileged_gt"
    },
    "provenance": {
      "type": "object"
    },
    "consistency_checks": {
      "type": "object"
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
