{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "record_id",
    "source_branch",
    "modalities",
    "assets",
    "provenance"
  ],
  "properties": {
    "record_id": {
      "type": "string"
    },
    "source_branch": {
      "enum": [
        "real_image",
        "existing_benchmark",
        "simulator"
      ]
    },
    "modalities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assets": {
      "type": "object"
    },
    "official_labels": {
      "type": "object"
    },
    "simulator_gt": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    },
    "license": {
      "type": "object"
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}