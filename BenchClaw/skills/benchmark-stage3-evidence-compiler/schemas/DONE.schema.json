{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "node_id",
    "status",
    "output_dir",
    "timestamp_utc"
  ],
  "properties": {
    "node_id": {
      "type": "string"
    },
    "status": {
      "const": "DONE"
    },
    "output_dir": {
      "type": "string"
    },
    "timestamp_utc": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}