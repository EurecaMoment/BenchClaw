{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "node_id",
    "inputs"
  ],
  "properties": {
    "node_id": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "purpose"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    }
  }
}