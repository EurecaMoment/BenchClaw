{
  "stage": "stage5",
  "executable_gate": {
    "command": "python3 BENCHCLAW_ROOT/skills/validate_stage_gate.py --workspace-root WORKSPACE_ROOT --stage stage5 --report WORKSPACE_ROOT/stage5/stage5_gate_report.json",
    "required_before": [
      "stage5/_STAGE_DONE.json",
      "pipeline Stage5 PASS",
      "PIPELINE_DONE.json",
      "WORKSPACE_ROOT/EVALSET_DATASET complete package"
    ]
  },
  "artifacts": [
    {
      "id": "workspace_evalset_dataset",
      "required_at_workspace_root": "EVALSET_DATASET",
      "required_files": [
        "README.md",
        "data/test.jsonl",
        "ground_truth/answers.jsonl",
        "metrics/score_predictions.py"
      ],
      "required_nonempty_directories": [
        "images",
        "ground_truth",
        "metrics"
      ],
      "must_be_stage5_consumed": true,
      "model_visible_forbidden_keys": [
        "answer",
        "answers",
        "gold_answer",
        "ground_truth",
        "gt",
        "metadata",
        "provenance",
        "object_provenance",
        "evidence_refs",
        "evidence_ref",
        "bbox",
        "bboxes",
        "depth",
        "area",
        "gt_*",
        "gold_*"
      ]
    },
    {
      "id": "data_23_evaluation_report",
      "required_files": [
        "evaluation_report.md",
        "metrics.json",
        "prediction_audit.jsonl",
        "error_taxonomy.jsonl",
        "opencode_usage_report.json",
        "opencode_usage_report.txt"
      ],
      "nonempty_jsonl": [
        "prediction_audit.jsonl",
        "error_taxonomy.jsonl"
      ],
      "provenance_required_in": [
        "stage5/nodes/full-evaluation/USED_INPUTS.json",
        "stage5/nodes/full-evaluation/NODE_REPORT.md"
      ]
    }
  ]
}
