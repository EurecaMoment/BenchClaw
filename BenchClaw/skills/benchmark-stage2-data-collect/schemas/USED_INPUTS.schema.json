{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage2 used inputs log",
  "type": "object",
  "required": [
    "node_id",
    "used_inputs"
  ],
  "properties": {
    "node_id": {
      "type": "string"
    },
    "used_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}