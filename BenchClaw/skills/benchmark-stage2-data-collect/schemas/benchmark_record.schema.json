{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Existing benchmark manifest record",
  "type": "object",
  "required": [
    "sample_id",
    "benchmark_name",
    "raw_data_path",
    "modalities",
    "split",
    "official_label_available",
    "provenance"
  ],
  "properties": {
    "sample_id": {
      "type": "string"
    },
    "benchmark_name": {
      "type": "string"
    },
    "raw_data_path": {
      "type": "string"
    },
    "modalities": {
      "type": "array"
    },
    "question": {
      "type": "string"
    },
    "answer": {
      "type": "string"
    },
    "split": {
      "type": "string"
    },
    "target_dimensions": {
      "type": "array"
    },
    "official_label_available": {
      "type": "boolean"
    },
    "license": {
      "type": "string"
    },
    "provenance": {
      "type": "object"
    }
  }
}