{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GT manifest record",
  "type": "object",
  "required": [
    "sample_id",
    "gt_field",
    "gt_source",
    "confidence"
  ],
  "properties": {
    "sample_id": {
      "type": "string"
    },
    "gt_field": {
      "type": "string"
    },
    "gt_value_path_or_inline": {},
    "gt_source": {
      "type": "string"
    },
    "simulator_query": {
      "type": "string"
    },
    "confidence": {
      "type": "number"
    },
    "timestamp_or_frame_id": {
      "type": "string"
    }
  }
}