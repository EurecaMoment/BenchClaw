{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Real image manifest record",
  "type": "object",
  "required": [
    "sample_id",
    "image_path",
    "source",
    "target_dimensions",
    "expected_annotation_fields",
    "gt_status",
    "provenance"
  ],
  "properties": {
    "sample_id": {
      "type": "string"
    },
    "image_path": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "capture_metadata": {
      "type": "object"
    },
    "target_dimensions": {
      "type": "array"
    },
    "expected_annotation_fields": {
      "type": "array"
    },
    "gt_status": {
      "enum": [
        "not_available",
        "official_available",
        "metadata_available"
      ]
    },
    "provenance": {
      "type": "object"
    }
  }
}