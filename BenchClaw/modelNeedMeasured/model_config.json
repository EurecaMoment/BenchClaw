{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "local_qwen08b": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Qwen 0.8B",
      "options": {
        "baseURL": "http://127.0.0.1:9001/v1",
        "apiKey": "EMPTY",
        "timeout": 300000,
        "chunkTimeout": 300000
      },
      "models": {
        "qwen0.8b": {
          "name": "Qwen3.5-0.8B (Local)",
          "api_model": "qwen3.5-0.8b",
          "capabilities": {
            "multimodal": true
          }
        }
      }
    },
    "local_qwen35b": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Qwen 35B",
      "options": {
        "baseURL": "http://127.0.0.1:9000/v1",
        "apiKey": "EMPTY",
        "timeout": 300000,
        "chunkTimeout": 300000
      },
      "models": {
        "qwen35b": {
          "name": "Qwen3.6-35B-A3B (Local)",
          "api_model": "qwen3.6-35b-a3b",
          "capabilities": {
            "multimodal": true
          }
        }
      }
    }
  },
  "model": "local_qwen35b/qwen35b",
  "small_model": "local_qwen08b/qwen0.8b",
  "grey_test": {
    "description": "Grey or canary evaluation model set.",
    "models": [
      "local_qwen08b/qwen0.8b",
      "local_qwen35b/qwen35b"
    ],
    "sampling": {
      "enabled": true,
      "max_items": 100
    },
    "fail_fast": true
  },
  "full_test": {
    "description": "Full benchmark evaluation model set.",
    "models": [
      "local_qwen08b/qwen0.8b",
      "local_qwen35b/qwen35b"
    ],
    "sampling": {
      "enabled": false
    },
    "fail_fast": false
  }
}
